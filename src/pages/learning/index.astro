---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('learning', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

// Featured project — most recent work
const featured = {
  title: 'Sound Design Lab',
  blurb:
    'An interactive educational tool for live sound engineers. Assign real speaker and amplifier components to positions in a Denver venue and get instant validation on impedance matching, power compatibility, and wiring safety — with SPL coverage prediction, audible fault auditioning, and live-graded guided missions.',
  stack: ['FastAPI', 'SQLAlchemy', 'React 18', 'Vite', 'Zustand', 'Tailwind', 'Web Audio API'],
  live: 'https://speakerblast.netlify.app/',
  source: 'https://github.com/acordivari/speaker_py',
};

// Earlier work, carried over from my former portfolio (andrewdc92.github.io)
const projects = [
  {
    title: 'Freelance CRM',
    blurb: 'Angular 2 microservice dashboard backed by a Rails API.',
    stack: ['Angular 2', 'Rails', 'Microservices'],
    href: 'https://github.com/andrewdc92/ang2_microservice_freelance_dash',
  },
  {
    title: 'U.S. Weather Data Visualizer',
    blurb: 'Charts and maps over U.S. weather data.',
    stack: ['React', 'Redux'],
    href: 'https://github.com/andrewdc92/react-redux-weather_app',
  },
  {
    title: 'IP Tracker',
    blurb: 'Look up and map an IP address in the browser.',
    stack: ['Angular'],
    href: 'https://andrewdc92.github.io/ip-tracker/',
  },
  {
    title: 'Blackworkers Directory',
    blurb: 'A directory app built on Rails.',
    stack: ['Ruby on Rails'],
    href: 'https://github.com/andrewdc92/blackworkers',
  },
  {
    title: 'Helping Hand',
    blurb: 'A community-assistance Rails application.',
    stack: ['Ruby on Rails'],
    href: 'https://github.com/andrewdc92/rails-ngo-app',
  },
  {
    title: 'UTravel',
    blurb: 'A travel-planning Rails application.',
    stack: ['Ruby on Rails'],
    href: 'https://github.com/andrewdc92/Vagabond',
  },
  {
    title: 'Hangular',
    blurb: 'A Hangman game built in Angular.',
    stack: ['Angular'],
    href: 'https://github.com/andrewdc92/ng-hangman',
  },
  {
    title: 'Personal Site (v1)',
    blurb: 'An earlier static portfolio built with Hugo.',
    stack: ['Hugo', 'Go'],
    href: 'https://andrewdc92.gitlab.io/andrew_c/',
  },
];

// Nested solid squares — each 94% of its parent, alternating dark/light fills
// so only a crisp frame of each shows. The dark layers rotate, and because the
// squares are nested, that rotation compounds down the tree into a logarithmic
// spiral that blooms as it sweeps — the mandala from andrewdc92.github.io.
function nestSquares(depth: number): string {
  if (depth === 0) return '';
  const dark = depth % 2 === 0;
  return `<div class="sq ${dark ? 'dark' : 'light'}">${nestSquares(depth - 1)}</div>`;
}
const squares = nestSquares(18);
---

<BaseLayout
  title="Learning & Projects"
  description="Notes on education and skills, plus a record of things I've built."
>
  <div class="page-header">
    <h1>Learning &amp; Projects</h1>
    <p class="lede">Personal projects I've worked on over the last 10 years.</p>
  </div>

  <div class="spiral-stage" aria-hidden="true">
    <div class="spiral" set:html={squares} />
  </div>

  <section class="projects">
    <div class="section-head">
      <h2>Things I've built</h2>
    </div>

    <article class="featured">
      <div class="featured-body">
        <span class="badge">Most recent</span>
        <h3>{featured.title}</h3>
        <p>{featured.blurb}</p>
        <ul class="stack">
          {featured.stack.map((tech) => <li>{tech}</li>)}
        </ul>
        <div class="links">
          <a href={featured.live} target="_blank" rel="noopener noreferrer" class="link-primary">
            View live &rarr;
          </a>
          <a href={featured.source} target="_blank" rel="noopener noreferrer" class="link-muted">
            Source
          </a>
        </div>
      </div>
    </article>

    <div class="project-grid">
      {projects.map((project) => (
        <a href={project.href} target="_blank" rel="noopener noreferrer" class="project-card">
          <h3>{project.title}</h3>
          <p>{project.blurb}</p>
          <ul class="stack">
            {project.stack.map((tech) => <li>{tech}</li>)}
          </ul>
        </a>
      ))}
    </div>
  </section>

  <section class="notes">
    <div class="section-head">
      <h2>Learning</h2>
    </div>

    {allTags.length > 0 && (
      <div class="tag-filter">
        <span class="filter-label">Filter</span>
        <ul class="tag-list">
          {allTags.map((tag) => (
            <li><a href={`/learning/tag/${tag}`}>{tag}</a></li>
          ))}
        </ul>
      </div>
    )}

    <div class="posts">
      {sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <article class="post-row">
            <a href={`/learning/${post.slug}`}>
              <div class="post-body">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="tags">
                    {post.data.tags.map((tag: string) => <li>{tag}</li>)}
                  </ul>
                )}
              </div>
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
          </article>
        ))
      ) : (
        <p class="empty">No posts yet.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* ─── Rotating-squares centerpiece ─────────────── */
  .spiral-stage {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .spiral {
    position: relative;
    width: min(340px, 70vw);
    aspect-ratio: 1;
  }

  /* Each square is 94% of its parent and centred via negative margin, leaving
     the transform free to rotate. Nesting makes the rotation compound. */
  .spiral :global(.sq) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 94%;
    height: 94%;
    margin: -47% 0 0 -47%;
    transform-origin: center;
    will-change: transform;
  }

  .spiral :global(.sq.dark) {
    background: var(--color-text);
    animation: mandala 13s linear infinite;
  }

  .spiral :global(.sq.light) {
    background: var(--color-bg);
  }

  /* A 90° sweep loops seamlessly — a square looks identical every quarter turn. */
  @keyframes mandala {
    from { transform: rotate(90deg); }
    to { transform: rotate(180deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .spiral :global(.sq.dark) {
      animation: none;
      transform: rotate(135deg); /* freeze mid-bloom */
    }
  }

  /* ─── Section heads ────────────────────────────── */
  .section-head {
    padding: 3rem 0 1.75rem;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  /* ─── Featured project ─────────────────────────── */
  .featured {
    border: 1px solid var(--color-text);
    padding: 2.5rem;
    margin-bottom: 2rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-nav-text);
    background: var(--color-nav-bg);
    padding: 0.25rem 0.5rem;
    margin-bottom: 1rem;
  }

  .featured h3 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 0.875rem;
  }

  .featured p {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: 1.25rem;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .link-primary {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 0.125rem;
  }

  .link-primary:hover {
    opacity: 0.6;
  }

  .link-muted {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
  }

  .link-muted:hover {
    color: var(--color-text);
  }

  /* ─── Project grid ─────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .project-card {
    display: block;
    background: var(--color-bg);
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .project-card:hover {
    background: #fafafa;
  }

  .project-card h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    margin-bottom: 0.5rem;
  }

  .project-card:hover h3 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .project-card p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  /* ─── Stack tags (shared) ──────────────────────── */
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .stack li {
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  /* ─── Notes ────────────────────────────────────── */
  .tag-filter {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tag-list a {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    transition: border-color 0.15s, color 0.15s;
  }

  .tag-list a:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    border-bottom: 1px solid var(--color-border);
  }

  .post-row a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-row a:hover h3 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body {
    flex: 1;
  }

  .post-row h3 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .post-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  .post-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.125rem;
  }

  .empty {
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 600px) {
    .featured {
      padding: 1.75rem;
    }

    .post-row a {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
