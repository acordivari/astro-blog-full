---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('learning', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title="Learning" description="Notes on education, skills, and continuous learning.">
  <div class="page-header">
    <span class="eyebrow">Notes</span>
    <h1>Learning</h1>
    <p class="lede">Notes on education, skills, and continuous learning.</p>
  </div>

  {allTags.length > 0 && (
    <div class="tag-filter">
      <span class="filter-label">Filter</span>
      <ul class="tag-list">
        {allTags.map((tag) => (
          <li><a href={`/learning/tag/${tag}`}>{tag}</a></li>
        ))}
      </ul>
    </div>
  )}

  <section class="posts">
    {sortedPosts.length > 0 ? (
      sortedPosts.map((post) => (
        <article class="post-row">
          <a href={`/learning/${post.slug}`}>
            <div class="post-body">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <ul class="tags">
                  {post.data.tags.map((tag: string) => <li>{tag}</li>)}
                </ul>
              )}
            </div>
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </a>
        </article>
      ))
    ) : (
      <p class="empty">No posts yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .eyebrow {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .tag-filter {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tag-list a {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    transition: border-color 0.15s, color 0.15s;
  }

  .tag-list a:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    border-bottom: 1px solid var(--color-border);
  }

  .post-row a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-row a:hover h2 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body {
    flex: 1;
  }

  .post-row h2 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .post-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  .post-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.125rem;
  }

  .empty {
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 600px) {
    .post-row a {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
