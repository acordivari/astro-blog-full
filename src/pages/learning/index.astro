---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('learning', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

// Newest initiative — a vintage tube-amp emulator
const tube = {
  title: 'Fender \'67 Tube Amp Emulator',
  blurb:
    'A C++ Audio Unit plugin that models a late 60s-era Fender tube amplifier circa 1967 — the clean headroom that breaks up into a warm, slightly overdriven blues tone. The signal chain runs an input drive stage into an 8×-oversampled asymmetric tube clipper (generating even-order harmonics), a 20 Hz DC blocker, and a 3rd-order Bassman tone stack derived from the actual passive Fender circuit via bilinear transform — so the famous midrange scoop falls out of the math rather than being faked. Cabinet loading convolves real speaker impulse responses, dynamic power sag models supply droop on transients, and a built-in test-tone generator lets you audition without a guitar.',
  stack: ['C++', 'JUCE', 'CMake', 'Audio Unit', 'macOS', 'DSP', 'Convolution'],
  source: 'https://github.com/acordivari/tube-emulator',
};

// Featured project — most recent work
const featured = {
  title: 'Sound Design Lab',
  blurb:
    'An interactive educational tool for live sound engineers. Assign real speaker and amplifier components to positions in a Denver venue and get instant validation on impedance matching, power compatibility, and wiring safety — with SPL coverage prediction, audible fault auditioning, and live-graded guided missions.',
  stack: ['FastAPI', 'SQLAlchemy', 'React 18', 'Vite', 'Zustand', 'Tailwind', 'Web Audio API'],
  live: 'https://speakerblast.netlify.app/',
  source: 'https://github.com/acordivari/speaker_py',
};

// A second featured card, mirroring the Sound Design Lab hero treatment
const tatu = {
  title: 'Tatu Artists Around the World',
  blurb:
    'A searchable encyclopedia of blackwork tattoo artists, rebuilt greenfield from a 2016 Rails 5 monolith into a Rails 8 JSON API and a React 19 SPA. Artists are derived automatically from Instagram captions, their images owned via Active Storage rather than hotlinked, and their locations resolved through a confidence-scored geocoding pipeline (Claude bio-extraction → Google-Places-verified shops → Nominatim) — so the directory can be searched, filtered by country and region, and plotted on an interactive map. Roughly 1,650 artists ingested from the @blackworkers feed and follow-list imports.',
  stack: ['Rails 8', 'Ruby 3.3', 'PostgreSQL', 'Active Storage', 'React 19', 'TypeScript', 'Vite', 'React Query', 'MapLibre GL', 'Apify'],
  source: 'https://github.com/acordivari/tatu-repo',
};

// Hero card — identity-backed agentic payments combining x401 + x402
const x402 = {
  title: 'x401 + x402 — Open Source Identity-backed Agentic Payments',
  blurb:
    'Two complementary open-source protocols for letting autonomous agents act on a human’s behalf — first proving who they are, then paying within their mandate. x401 (Proof’s HTTP-native proof-requirement protocol, the 401 analog to x402’s payments) gates a route behind a credential proof: a verifier declares what must be proven — personhood, residency, membership, organizational standing, or workload identity — and an agent presents a verifiable credential to gain access, built on the W3C Digital Credentials API, OpenID4VP, and OAuth 2.0. x402 then handles the payment: an agent hits an HTTP 402, signs an EIP-3009 USDC authorization, and a facilitator settles gaslessly on-chain (Base Sepolia). On top sits a Human Authorization Mandate (HAM) layer answering the question x402 leaves open — which human authorized this agent to spend, and within what scope — enforcing intent, cart, and payment validation through a guarded order state machine (CREATED → QUOTED → AUTHORIZED → SETTLING → SETTLED) with idempotent settlement retries. First live on-chain settlement landed June 2026.',
  stack: ['TypeScript', 'x401', 'x402 v2', 'W3C Digital Credentials API', 'OpenID4VP', 'OAuth 2.0', 'Coinbase CDP Wallet', 'viem', 'EIP-3009', 'Base Sepolia', 'USDC', 'Zod'],
  source: 'https://github.com/acordivari/coinbase-x402-implementation',
  spec: 'https://x401.proof.com/spec/latest/',
};

// Earlier work, carried over from my former portfolio (andrewdc92.github.io)
const projects = [
  {
    title: 'IP Tracker',
    blurb: 'A dependency-free rewrite of an old AngularJS app — looks up your public IP and renders its geolocation (city, region, coordinates, ISP) client-side, with a fallback between providers for reliability.',
    stack: ['Vanilla JS', 'Vite', 'Geolocation API', 'GitHub Actions'],
    href: 'https://github.com/acordivari/ip-tracker-rewrite',
  },
  {
    title: 'Freelance CRM',
    blurb: 'A rewrite of a 2017 Angular 2 + Rails-microservices app — lets freelance designers draft, organize, and email client proposals from a live-updating dashboard, now on Angular 20 standalone components talking JSON to a single Rails 8 API.',
    stack: ['Angular 20', 'TypeScript', 'Rails 8 API', 'PostgreSQL', 'Bootstrap 5'],
    href: 'https://github.com/acordivari/angular-freelance-crm-rewrite',
  },
  {
    title: 'UTravel',
    blurb: 'A ground-up rewrite of an old Rails 5 app — members write travel journals about cities and discuss them in comments, rebuilt as a server-rendered Hotwire monolith with Active Storage image uploads and server-side authorization.',
    stack: ['Rails 8', 'Ruby 3.3', 'Hotwire', 'Tailwind CSS', 'PostgreSQL'],
    href: 'https://github.com/acordivari/rails-travel-journal-rewrite/tree/main/vagabond_app',
  },
];

// Nested solid squares — each 94% of its parent, alternating dark/light fills
// so only a crisp frame of each shows. The dark layers rotate, and because the
// squares are nested, that rotation compounds down the tree into a logarithmic
// spiral that blooms as it sweeps — the mandala from andrewdc92.github.io.
function nestSquares(depth: number): string {
  if (depth === 0) return '';
  const dark = depth % 2 === 0;
  return `<div class="sq ${dark ? 'dark' : 'light'}">${nestSquares(depth - 1)}</div>`;
}
const squares = nestSquares(18);
---

<BaseLayout
  title="Learning & Projects"
  description="Notes on education and skills, plus a record of things I've built."
>
  <div class="page-header">
    <h1>Learning &amp; Projects</h1>
    <p class="lede">Personal projects I've worked on over the last few years.</p>
  </div>

  <div class="spiral-stage" aria-hidden="true">
    <div class="spiral" set:html={squares} />
  </div>

  <section class="projects">
    <div class="section-head">
      <h2>Things I've built</h2>
    </div>

    <article class="featured">
      <div class="featured-body">
        <span class="badge">Most recent</span>
        <h3>{x402.title}</h3>
        <p>{x402.blurb}</p>
        <ul class="stack">
          {x402.stack.map((tech) => <li>{tech}</li>)}
        </ul>
        <div class="links">
          <a href={x402.source} target="_blank" rel="noopener noreferrer" class="link-primary">
            Source &rarr;
          </a>
          <a href={x402.spec} target="_blank" rel="noopener noreferrer" class="link-muted">
            Read the x401 spec
          </a>
        </div>
      </div>
    </article>

    <article class="featured">
      <div class="featured-body">
        <span class="badge">Recent work</span>
        <h3>{tube.title}</h3>
        <p>{tube.blurb}</p>
        <ul class="stack">
          {tube.stack.map((tech) => <li>{tech}</li>)}
        </ul>
        <div class="links">
          <a href={tube.source} target="_blank" rel="noopener noreferrer" class="link-primary">
            Source &rarr;
          </a>
        </div>
      </div>
    </article>

    <article class="featured">
      <div class="featured-body">
        <span class="badge">Recent work</span>
        <h3>{featured.title}</h3>
        <p>{featured.blurb}</p>
        <ul class="stack">
          {featured.stack.map((tech) => <li>{tech}</li>)}
        </ul>
        <div class="links">
          <a href={featured.live} target="_blank" rel="noopener noreferrer" class="link-primary">
            View live &rarr;
          </a>
          <a href={featured.source} target="_blank" rel="noopener noreferrer" class="link-muted">
            Source
          </a>
        </div>
      </div>
    </article>

    <article class="featured">
      <div class="featured-body">
        <span class="badge">Earlier work</span>
        <h3>{tatu.title}</h3>
        <p>{tatu.blurb}</p>
        <ul class="stack">
          {tatu.stack.map((tech) => <li>{tech}</li>)}
        </ul>
        <div class="links">
          <a href={tatu.source} target="_blank" rel="noopener noreferrer" class="link-primary">
            Source &rarr;
          </a>
        </div>
      </div>
    </article>

    <div class="project-grid">
      {projects.map((project) => (
        <a href={project.href} target="_blank" rel="noopener noreferrer" class="project-card">
          <h3>{project.title}</h3>
          <p>{project.blurb}</p>
          <ul class="stack">
            {project.stack.map((tech) => <li>{tech}</li>)}
          </ul>
        </a>
      ))}
    </div>
  </section>

  <section class="notes">
    <div class="section-head">
      <h2>Learning</h2>
    </div>

    {allTags.length > 0 && (
      <div class="tag-filter">
        <span class="filter-label">Filter</span>
        <ul class="tag-list">
          {allTags.map((tag) => (
            <li><a href={`/learning/tag/${tag}`}>{tag}</a></li>
          ))}
        </ul>
      </div>
    )}

    <div class="posts">
      {sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <article class="post-row">
            <a href={`/learning/${post.slug}`}>
              <div class="post-body">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="tags">
                    {post.data.tags.map((tag: string) => <li>{tag}</li>)}
                  </ul>
                )}
              </div>
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
          </article>
        ))
      ) : (
        <p class="empty">No posts yet.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* ─── Rotating-squares centerpiece ─────────────── */
  .spiral-stage {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .spiral {
    position: relative;
    width: min(340px, 70vw);
    aspect-ratio: 1;
  }

  /* Each square is 94% of its parent and centred via negative margin, leaving
     the transform free to rotate. Nesting makes the rotation compound. */
  .spiral :global(.sq) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 94%;
    height: 94%;
    margin: -47% 0 0 -47%;
    transform-origin: center;
    will-change: transform;
  }

  .spiral :global(.sq.dark) {
    background: var(--color-text);
    animation: mandala 13s linear infinite;
  }

  .spiral :global(.sq.light) {
    background: var(--color-bg);
  }

  /* A 90° sweep loops seamlessly — a square looks identical every quarter turn. */
  @keyframes mandala {
    from { transform: rotate(90deg); }
    to { transform: rotate(180deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .spiral :global(.sq.dark) {
      animation: none;
      transform: rotate(135deg); /* freeze mid-bloom */
    }
  }

  /* ─── Section heads ────────────────────────────── */
  .section-head {
    padding: 3rem 0 1.75rem;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  /* ─── Featured project ─────────────────────────── */
  .featured {
    border: 1px solid var(--color-text);
    padding: 2.5rem;
    margin-bottom: 2rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-nav-text);
    background: var(--color-nav-bg);
    padding: 0.25rem 0.5rem;
    margin-bottom: 1rem;
  }

  .featured h3 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 0.875rem;
  }

  .featured p {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: 1.25rem;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .link-primary {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 0.125rem;
  }

  .link-primary:hover {
    opacity: 0.6;
  }

  .link-muted {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
  }

  .link-muted:hover {
    color: var(--color-text);
  }

  /* ─── Project grid ─────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .project-card {
    display: block;
    background: var(--color-bg);
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .project-card:hover {
    background: #f2eee3;
  }

  .project-card h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    margin-bottom: 0.5rem;
  }

  .project-card:hover h3 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .project-card p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  /* ─── Stack tags (shared) ──────────────────────── */
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .stack li {
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  /* ─── Notes ────────────────────────────────────── */
  .tag-filter {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tag-list a {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    transition: border-color 0.15s, color 0.15s;
  }

  .tag-list a:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    border-bottom: 1px solid var(--color-border);
  }

  .post-row a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-row a:hover h3 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body {
    flex: 1;
  }

  .post-row h3 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .post-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  .post-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.125rem;
  }

  .empty {
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  /* Collapse the three-up grid to a single column before the cards get cramped.
     Going straight from 3 → 1 keeps every cell filled (no empty grey cells). */
  @media (max-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .featured {
      padding: 1.75rem;
    }

    .post-row a {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
