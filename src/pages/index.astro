---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reflections = await getCollection('reflections', ({ data }) => !data.draft);

const latestReflections = reflections
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Andrew Cordivari">
  <section class="hero">
    <p class="hero-eyebrow">Andrew Cordivari</p>
    <h1>Intersections of<br/>life, technology,<br/>nature, and<br/>awareness.</h1>
  </section>

  {latestReflections.length > 0 && (
    <section class="section">
      <div class="section-header">
        <span class="section-label">Reflections</span>
        <a href="/reflections" class="section-all">View all &rarr;</a>
      </div>
      <div class="reflection-list">
        {latestReflections.map((post) => (
          <article class="reflection-row">
            <a href={`/reflections/${post.slug}`}>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .hero-eyebrow {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--color-text);
  }

  .section {
    margin-bottom: 4rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
    margin-bottom: 2rem;
  }

  .section-label {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .section-all {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .section-all:hover {
    color: var(--color-text);
  }

  /* Reflection list */
  .reflection-list {
    display: flex;
    flex-direction: column;
  }

  .reflection-row {
    border-top: 1px solid var(--color-border);
  }

  .reflection-row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .reflection-row a {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    align-items: start;
    gap: 0.25rem 2rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
  }

  .reflection-row a:hover h3 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .reflection-row h3 {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    grid-column: 1;
    grid-row: 1;
  }

  .reflection-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    grid-column: 1;
    grid-row: 2;
  }

  .reflection-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    grid-column: 2;
    grid-row: 1;
    white-space: nowrap;
    padding-top: 0.125rem;
  }

  @media (max-width: 600px) {
    .reflection-row a {
      grid-template-columns: 1fr;
    }

    .reflection-row time {
      grid-column: 1;
      grid-row: 3;
    }
  }
</style>
