---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRecentPlaylists, feeds, getFeedEmbedUrl } from '../content/music';

const playlists = getRecentPlaylists(10);

function getCompactEmbedUrl(url: string): string {
  const parsed = new URL(url);
  parsed.searchParams.set('visual', 'false');
  return parsed.toString();
}
---

<BaseLayout title="Music — Andrew Cordivari" description="Recent listens, mixes, and sounds.">
  <div class="page-header">
    <h1>Music</h1>
    <p class="lede">Recent listens, mixes, and sounds.</p>
  </div>

  {playlists.length > 0 ? (
    <section class="playlists">
      {playlists.map((playlist) => (
        <article class="playlist">
          <div class="playlist-info">
            <h2>{playlist.name}</h2>
            {playlist.artist && <p class="artist">{playlist.artist}</p>}
            {playlist.description && <p class="description">{playlist.description}</p>}
          </div>
          <div class="player">
            <iframe
              width="100%"
              height="166"
              scrolling="no"
              frameborder="no"
              allow="autoplay"
              src={getCompactEmbedUrl(playlist.embedUrl)}
            ></iframe>
          </div>
        </article>
      ))}
    </section>
  ) : (
    <p class="empty">No playlists yet.</p>
  )}

  {feeds.length > 0 && (
    <section class="feeds">
      {feeds.map((feed) => (
        <article class="playlist">
          <div class="playlist-info">
            <h2>{feed.name}</h2>
            {feed.description && <p class="description">{feed.description}</p>}
          </div>
          <div class="player">
            <iframe
              width="100%"
              height="450"
              scrolling="no"
              frameborder="no"
              allow="autoplay"
              src={getFeedEmbedUrl(feed.userId)}
            ></iframe>
          </div>
        </article>
      ))}
    </section>
  )}
</BaseLayout>

<style>
  .page-header {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .playlists,
  .feeds {
    display: flex;
    flex-direction: column;
  }

  .feeds {
    margin-top: 0;
  }

  .playlist {
    border-bottom: 1px solid var(--color-border);
    padding: 2rem 0;
  }

  .playlist-info {
    margin-bottom: 1.25rem;
  }

  .playlist-info h2 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .artist {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .description {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
    line-height: 1.5;
  }

  .player iframe {
    display: block;
  }

  .empty {
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 600px) {
    .page-header {
      padding: 2.5rem 0 2rem;
    }
  }
</style>
