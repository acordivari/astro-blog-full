---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagList from '../../components/TagList.astro';
import BrandList from '../../components/BrandList.astro';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews', ({ data }) => !data.draft);
const sortedReviews = reviews.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const allTags = [...new Set(reviews.flatMap((post) => post.data.tags))].sort();
const allBrands = [...new Set(reviews.map((post) => post.data.brand).filter(Boolean))].sort() as string[];
---

<BaseLayout title="Reviews" description="In-depth reviews of garments and brands.">
  <div class="page-header">
    <span class="eyebrow">Archive</span>
    <h1>Reviews</h1>
    <p class="lede">In-depth reviews of garments, brands, and construction.</p>
  </div>

  {allBrands.length > 0 && (
    <div class="filter-row">
      <span class="filter-label">Brand</span>
      <BrandList brands={allBrands} />
    </div>
  )}

  {allTags.length > 0 && (
    <div class="filter-row">
      <span class="filter-label">Tag</span>
      <TagList tags={allTags} />
    </div>
  )}

  <section class="posts">
    {sortedReviews.length > 0 ? (
      sortedReviews.map((post) => (
        <article class="post-row">
          <a href={`/reviews/${post.slug}`}>
            <div class="post-body">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="meta">
                {post.data.brand && <span class="brand">{post.data.brand}</span>}
                {post.data.tags.length > 0 && (
                  <ul class="tags">
                    {post.data.tags.map((tag: string) => <li>{tag}</li>)}
                  </ul>
                )}
              </div>
            </div>
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </a>
        </article>
      ))
    ) : (
      <p class="empty">No published reviews.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .eyebrow {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .filter-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    border-bottom: 1px solid var(--color-border);
  }

  .post-row a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-row a:hover h2 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body {
    flex: 1;
  }

  .post-row h2 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .post-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .brand {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  .post-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.125rem;
  }

  .empty {
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 600px) {
    .post-row a {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
