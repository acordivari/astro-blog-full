---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout
  title={`${entry.data.title} — Journal`}
  description={`${entry.data.type} · ${entry.data.project} · ${entry.data.date.toLocaleDateString('en-US')}`}
>
  <article class="entry" data-pagefind-body>
    <div class="article-header">
      <div class="entry-meta">
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span class={`type type-${entry.data.type}`}>{entry.data.type}</span>
        <span class="project">{entry.data.project}</span>
      </div>
      <h1>{entry.data.title}</h1>
      {entry.data.tags.length > 0 && (
        <div class="tags">
          {entry.data.tags.map((t) => <span class="tag" data-pagefind-filter="tag">{t}</span>)}
        </div>
      )}
    </div>

    <div class="content">
      <Content />
    </div>
  </article>

  <nav class="back">
    <a href="/journal">&larr; Back to Journal</a>
  </nav>
</BaseLayout>

<style>
  .entry {
    max-width: 68ch;
    margin: 0 auto;
  }

  .article-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .type {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.1em 0.5em;
    border-radius: 3px;
    border: 1px solid var(--color-border);
  }

  .type-change { color: #2d6a4f; }
  .type-learning { color: #6a4c93; }
  .type-plan { color: #9c6644; }

  .project {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 3px;
  }

  .content {
    font-size: 1rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .content :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.375rem;
  }

  .content :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85em;
    background: var(--color-border);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .content :global(pre) {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 6px;
    margin: 1.5rem 0;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .content :global(blockquote) {
    border-left: 2px solid var(--color-text);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-muted);
  }

  .back {
    max-width: 68ch;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back a {
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
    text-decoration: none;
  }

  .back a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
