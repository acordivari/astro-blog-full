---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('journal', ({ data }) => !data.draft);
const sorted = entries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Journal"
  description="A dated changelog of engineering changes, decisions, and learnings across projects."
>
  <div class="page-header">
    <h1>Journal</h1>
    <p class="lede">
      A dated changelog of engineering changes, decisions, and learnings across projects.
      Search with <kbd>/</kbd>.
    </p>
  </div>

  <section class="entries">
    {sorted.length > 0 ? (
      sorted.map((entry) => (
        <article class="entry-row">
          <a href={`/journal/${entry.slug}`}>
            <div class="entry-meta">
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <span class={`type type-${entry.data.type}`}>{entry.data.type}</span>
              <span class="project">{entry.data.project}</span>
            </div>
            <div class="entry-body">
              <h2>{entry.data.title}</h2>
              {entry.data.tags.length > 0 && (
                <div class="tags">
                  {entry.data.tags.map((t) => <span class="tag">{t}</span>)}
                </div>
              )}
            </div>
          </a>
        </article>
      ))
    ) : (
      <p class="empty">No journal entries yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 60ch;
  }

  kbd {
    font-family: inherit;
    font-size: 0.85em;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.05em 0.4em;
  }

  .entries {
    margin-top: 1rem;
  }

  .entry-row {
    border-bottom: 1px solid var(--color-border);
  }

  .entry-row a {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .entry-row a:hover h2 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }

  .type {
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.1em 0.5em;
    border-radius: 3px;
    border: 1px solid var(--color-border);
  }

  .type-change { color: #2d6a4f; }
  .type-learning { color: #6a4c93; }
  .type-plan { color: #9c6644; }

  .project {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .entry-body h2 {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 3px;
  }

  .empty {
    padding: 3rem 0;
    color: var(--color-muted);
  }
</style>
