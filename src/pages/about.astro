---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import PersonSchema from '../components/PersonSchema.astro';
---

<BaseLayout
  title="About — Andrew Cordivari"
  description="Who Andrew Cordivari is and what he does — enterprise support and solutions engineer at Proof, musician, and movement practitioner."
>
  <PersonSchema />
  <article class="about">
    <div class="about-header">
      <h1>About me.</h1>
    </div>

    <div class="prose">
      <h2>Who I am</h2>

      <p class="oneline">Human, husband, brother, son, student, friend</p>

      <h2>What I do</h2>

      <p>Problem solver, musician, movement practitioner, trying, failing, trying again, sometimes succeeding</p>

      <p>Professionally, I'm a Senior Technical Consultant II at Proof (formerly Notarize) — an enterprise support and solutions engineer. At heart, a curious person who goes deep across domains: equally at home debugging production systems, writing code, and explaining hard technical ideas clearly.</p>

      <h2>Contact</h2>

      <p>
        <a href="mailto:andrew@thisisandrew.me">andrew@thisisandrew.me</a>
      </p>

      <SocialLinks />
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: 60ch;
    margin: 0 auto;
  }

  .about-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .prose {
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose p {
    margin-bottom: 1.25rem;
  }

  .prose h2 {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 400;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  /* First section heading sits right under the header's divider — drop its own
     rule so the page shows a single line, like the other pages. */
  .prose h2:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  /* Keep this short list on one line at every width by scaling the type down
     on narrow viewports rather than letting it wrap. */
  .oneline {
    white-space: nowrap;
    font-size: min(1rem, 3.6vw);
  }

  .prose ul {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .prose li {
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9375rem;
  }

  .prose strong {
    font-weight: 600;
  }

  .prose a {
    color: var(--color-text);
    text-underline-offset: 3px;
  }

  /* Give the shared social links a little breathing room under the email line. */
  .prose :global(.social-links) {
    margin-top: 1.5rem;
  }
</style>
