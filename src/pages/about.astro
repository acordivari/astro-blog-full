---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Andrew Cordivari">
  <article class="about">
    <div class="about-header">
      <h1>About me.</h1>
    </div>

    <div class="prose">
      <h2>Who I am</h2>

      <p class="oneline">Human, husband, brother, son, student, friend</p>

      <h2>What I do</h2>

      <p>Problem solver, musician, movement practitioner, trying, failing, trying again, sometimes succeeding</p>

      <h2>Contact</h2>

      <p>
        <a href="mailto:andrew@thisisandrew.me">andrew@thisisandrew.me</a>
      </p>

      <ul class="contact-icons">
        <li>
          <a href="https://www.linkedin.com/in/andrewcordivari" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://github.com/acordivari" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </li>
        <li>
          <a href="mailto:andrew@thisisandrew.me" aria-label="Email">
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: 60ch;
    margin: 0 auto;
  }

  .about-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .prose {
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose p {
    margin-bottom: 1.25rem;
  }

  .prose h2 {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 400;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  /* First section heading sits right under the header's divider — drop its own
     rule so the page shows a single line, like the other pages. */
  .prose h2:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  /* Keep this short list on one line at every width by scaling the type down
     on narrow viewports rather than letting it wrap. */
  .oneline {
    white-space: nowrap;
    font-size: min(1rem, 3.6vw);
  }

  .prose ul {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .prose li {
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9375rem;
  }

  .prose strong {
    font-weight: 600;
  }

  .prose a {
    color: var(--color-text);
    text-underline-offset: 3px;
  }

  .prose .contact-icons {
    flex-direction: row;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .prose .contact-icons li {
    padding: 0;
    border-bottom: none;
  }

  .prose .contact-icons a {
    display: inline-flex;
    color: var(--color-muted);
    transition: color 0.15s;
  }

  .prose .contact-icons a:hover {
    color: var(--color-text);
  }

  .prose .contact-icons svg {
    width: 20px;
    height: 20px;
    display: block;
  }
</style>
