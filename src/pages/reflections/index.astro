---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reflections = await getCollection('reflections', ({ data }) => !data.draft);
const sortedReflections = reflections.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title="Reflections" description="Personal thoughts on style, craft, and material culture.">
  <div class="page-header">
    <h1>Reflections</h1>
    <p class="lede">Personal thoughts on style, craft, and material culture.</p>
  </div>

  <section class="posts">
    {sortedReflections.length > 0 ? (
      sortedReflections.map((post) => (
        <article class="post-row">
          <a href={`/reflections/${post.slug}`}>
            <div class="post-body">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </a>
        </article>
      ))
    ) : (
      <p class="empty">No reflections yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    border-bottom: 1px solid var(--color-border);
  }

  .post-row a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-row a:hover h2 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body {
    flex: 1;
  }

  .post-row h2 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .post-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .post-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .empty {
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  @media (max-width: 600px) {
    .post-row a {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
