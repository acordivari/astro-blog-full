---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const reflections = await getCollection('reflections', ({ data }) => !data.draft);
  return reflections.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} — Reflections`}
  description={post.data.description}
  image={post.data.image}
  type="article"
  publishDate={post.data.publishDate}
>
  <article class="reflection" data-pagefind-body>
    <div class="article-header">
      <h1>{post.data.title}</h1>
      <time datetime={post.data.publishDate.toISOString()}>
        {post.data.publishDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
    </div>

    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.imageAlt || post.data.title}
        class="featured-image"
      />
    )}

    <div class="content">
      <Content />
    </div>
  </article>

  <nav class="back">
    <a href="/reflections">&larr; Back to Reflections</a>
  </nav>
</BaseLayout>

<style>
  .reflection {
    max-width: 68ch;
    margin: 0 auto;
  }

  .article-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }

  time {
    display: block;
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .featured-image {
    width: 100%;
    margin-bottom: 2.5rem;
  }

  .content {
    font-size: 1rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  .content :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(img) {
    margin: 1.5rem 0;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.375rem;
  }

  .content :global(blockquote) {
    border-left: 2px solid var(--color-text);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-muted);
  }

  .back {
    max-width: 68ch;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back a {
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
    text-decoration: none;
  }

  .back a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
