---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkoutCalendar from '../../components/WorkoutCalendar.astro';
import TagList from '../../components/TagList.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('movement', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title="Movement" description="A physical practice journal.">
  <div class="page-header">
    <h1>Movement</h1>
    <p class="lede">A physical practice journal.</p>
  </div>

  <WorkoutCalendar />

  {allTags.length > 0 && (
    <div class="tag-filter">
      <span class="filter-label">Filter</span>
      <TagList tags={allTags} basePath="/movement/tag" />
    </div>
  )}

  <section class="posts">
    {sortedPosts.map((post) => (
      <article class="post-row">
        <a href={`/movement/${post.slug}`}>
          <div class="post-body">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <ul class="tags">
                {post.data.tags.map((tag: string) => <li>{tag}</li>)}
              </ul>
            )}
          </div>
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .tag-filter {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    border-bottom: 1px solid var(--color-border);
  }

  .post-row a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-row a:hover h2 {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body {
    flex: 1;
  }

  .post-row h2 {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .post-row p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
  }

  .post-row time {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.125rem;
  }

  @media (max-width: 600px) {
    .post-row a {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
