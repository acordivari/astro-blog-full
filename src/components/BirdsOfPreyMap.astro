---
// BirdsOfPreyMap — Displays birds of prey sightings near Boulder, CO
// Uses GBIF Occurrence API and Leaflet.js
---

<div id="birds-map-container">
  <div class="birds-header">
    <h2 id="birds-heading">Birds of Prey Near Boulder, CO</h2>
    <p class="birds-subtitle" id="birds-subtitle">Recent sightings within 100 miles of Boulder, CO — from GBIF</p>
  </div>

  <form class="birds-search" id="birds-search-form">
    <input
      type="text"
      id="birds-address"
      class="birds-address-input"
      placeholder="Enter an address, city, or place — e.g. Denver, CO"
      autocomplete="off"
      aria-label="Address or place to search for birds of prey"
    />
    <button type="submit" id="birds-search-btn">Search</button>
  </form>

  <div class="birds-radius">
    <label for="birds-radius-slider">Search radius: <span id="birds-radius-value">100</span> miles</label>
    <input type="range" id="birds-radius-slider" min="10" max="150" step="5" value="100" />
  </div>

  <div id="birds-place" class="birds-place"></div>

  <div class="birds-controls">
    <select id="birds-taxon">
      <option value="all">All Birds of Prey</option>
      <option value="2877">Hawks, Eagles & Kites (Accipitriformes)</option>
      <option value="7191">Falcons (Falconiformes)</option>
      <option value="1458">Owls (Strigiformes)</option>
    </select>
    <button id="birds-refresh">Refresh Data</button>
  </div>

  <div id="birds-loading" class="birds-message">Loading bird sightings...</div>
  <div id="birds-error" class="birds-message birds-error" style="display:none"></div>

  <div id="birds-map"></div>

  <div id="birds-insights" class="birds-insights" style="display:none"></div>

  <div id="birds-species-section" class="birds-species-section">
    <h3>Species Found <span id="birds-species-count-label"></span></h3>
    <p class="birds-section-subtitle">Click a species for photos and details</p>
    <div id="birds-species-grid" class="birds-species-grid"></div>
  </div>

  <div class="birds-stats">
    <span id="birds-count">0 sightings</span>
    <span id="birds-species">0 species</span>
    <span id="birds-cache-status" class="cache-status"></span>
  </div>

  <p class="birds-attribution">
    Data from <a href="https://www.gbif.org" target="_blank" rel="noopener">GBIF.org</a> |
    Photos from <a href="https://www.inaturalist.org" target="_blank" rel="noopener">iNaturalist</a> |
    Descriptions from <a href="https://www.wikipedia.org" target="_blank" rel="noopener">Wikipedia</a>
  </p>
</div>

<!-- Species Detail Modal -->
<div id="species-modal" class="species-modal">
  <div class="species-modal-backdrop"></div>
  <div class="species-modal-content">
    <button id="species-modal-close" class="species-modal-close">&times;</button>

    <div id="species-modal-loading" class="species-modal-loading">
      Loading species information...
    </div>

    <div id="species-modal-body" class="species-modal-body" style="display:none">
      <div class="species-modal-gallery">
        <img id="species-modal-image" src="" alt="" />
        <div id="species-modal-thumbnails" class="species-modal-thumbnails"></div>
      </div>

      <div class="species-modal-info">
        <h2 id="species-modal-name"></h2>
        <p id="species-modal-common" class="species-common-name"></p>

        <div class="species-meta">
          <span id="species-modal-order" class="species-tag"></span>
          <span id="species-modal-family" class="species-tag"></span>
          <span id="species-modal-sightings" class="species-tag"></span>
        </div>

        <div id="species-modal-description" class="species-description"></div>

        <div id="species-modal-fieldnotes" class="species-fieldnotes"></div>
        <div id="species-modal-wingspan" class="species-wingspan"></div>
        <div id="species-modal-seasonality" class="species-seasonality"></div>

        <div class="species-links">
          <a id="species-link-wikipedia" href="#" target="_blank" rel="noopener">Wikipedia</a>
          <a id="species-link-inaturalist" href="#" target="_blank" rel="noopener">iNaturalist</a>
          <a id="species-link-gbif" href="#" target="_blank" rel="noopener">GBIF</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
  import { getRaptorInfo, WINGSPAN_REFERENCES, WINGSPAN_AXIS_MAX_CM } from '../data/raptors';
  import type { RaptorInfo } from '../data/raptors';

  // Load Leaflet dynamically
  const leafletScript = document.createElement('script');
  leafletScript.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  leafletScript.onload = initMap;
  document.head.appendChild(leafletScript);

  // Default location: Boulder, CO — preserves the original view and the personal story
  const DEFAULT_LAT = 40.015;
  const DEFAULT_LNG = -105.2705;
  const DEFAULT_PLACE = 'Boulder, CO';
  const MILES_TO_KM = 1.60934;

  // Mutable search state — driven by the address box and radius slider
  let currentLat = DEFAULT_LAT;
  let currentLng = DEFAULT_LNG;
  let currentRadiusMiles = 100;
  let currentPlaceName = DEFAULT_PLACE;

  // Leaflet layers for the search center + radius ring (redrawn on every search)
  let centerMarker: any = null;
  let radiusCircle: any = null;

  // GBIF taxon keys for birds of prey
  const TAXON_KEYS = {
    all: [2877, 7191, 1458], // Accipitriformes, Falconiformes, Strigiformes
    2877: [2877], // Hawks, Eagles
    7191: [7191], // Falcons
    1458: [1458], // Owls
  };

  // Valid raptor orders - strict filter to exclude any non-raptor species
  const VALID_RAPTOR_ORDERS = ['Accipitriformes', 'Falconiformes', 'Strigiformes'];

  // Cache configuration - using IndexedDB for larger storage
  const DB_NAME = 'birds-of-prey-db';
  const DB_VERSION = 1;
  const STORE_NAME = 'cache';

  interface CachedData {
    id: string;
    timestamp: number;
    occurrences: any[];
    speciesNames: Record<string, string>;
  }

  let map: any;
  let markers: any[] = [];
  let cachedOccurrences: any[] = [];
  let cachedSpeciesNames: Record<string, string> = {};

  // Species data for current view
  interface SpeciesInfo {
    scientificName: string;
    vernacularName: string;
    order: string;
    family: string;
    count: number;
    gbifKey: number;
  }
  let speciesData: Map<string, SpeciesInfo> = new Map();

  // IndexedDB helper functions
  function openDB(): Promise<IDBDatabase> {
    return new Promise((resolve, reject) => {
      const request = indexedDB.open(DB_NAME, DB_VERSION);
      request.onerror = () => reject(request.error);
      request.onsuccess = () => resolve(request.result);
      request.onupgradeneeded = (event) => {
        const db = (event.target as IDBOpenDBRequest).result;
        if (!db.objectStoreNames.contains(STORE_NAME)) {
          db.createObjectStore(STORE_NAME, { keyPath: 'id' });
        }
      };
    });
  }

  // Cache is keyed per location + radius so different searches don't clobber each other.
  function cacheKey(lat: number, lng: number, radiusMiles: number): string {
    return `birds:${lat.toFixed(2)}:${lng.toFixed(2)}:${radiusMiles}`;
  }

  async function loadFromCache(key: string): Promise<CachedData | null> {
    try {
      const db = await openDB();
      return new Promise((resolve, reject) => {
        const tx = db.transaction(STORE_NAME, 'readonly');
        const store = tx.objectStore(STORE_NAME);
        const request = store.get(key);
        request.onerror = () => reject(request.error);
        request.onsuccess = () => {
          const data = request.result as CachedData | undefined;
          if (data) {
            console.log('Loaded from IndexedDB:', key, data.occurrences.length, 'occurrences');
          } else {
            console.log('No cache in IndexedDB for', key);
          }
          resolve(data || null);
        };
      });
    } catch (e) {
      console.error('Error loading cache:', e);
      return null;
    }
  }

  async function saveToCache(key: string, occurrences: any[], speciesNames: Record<string, string>) {
    try {
      const db = await openDB();
      const timestamp = Date.now();
      const data: CachedData = {
        id: key,
        timestamp,
        occurrences,
        speciesNames,
      };

      return new Promise<void>((resolve, reject) => {
        const tx = db.transaction(STORE_NAME, 'readwrite');
        const store = tx.objectStore(STORE_NAME);
        const request = store.put(data);
        request.onerror = () => reject(request.error);
        request.onsuccess = () => {
          console.log('Saved to IndexedDB:', occurrences.length, 'occurrences,', Object.keys(speciesNames).length, 'species names');
          updateCacheStatus(timestamp, true);
          resolve();
        };
      });
    } catch (e) {
      console.warn('Failed to save to cache:', e);
    }
  }

  function updateCacheStatus(timestamp: number, justRefreshed = false) {
    const el = document.getElementById('birds-cache-status');
    if (!el) return;

    const date = new Date(timestamp);
    const timeStr = date.toLocaleString('en-US', {
      month: 'short',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    });

    if (justRefreshed) {
      el.textContent = `Updated just now`;
      el.className = 'cache-status fresh';
    } else {
      el.textContent = `Cached: ${timeStr}`;
      el.className = 'cache-status';
    }
  }

  async function initMap() {
    const L = (window as any).L;

    // Initialize map centered on the default location
    map = L.map('birds-map').setView([currentLat, currentLng], 8);

    // Add OpenStreetMap tiles
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 18,
    }).addTo(map);

    redrawCenter(false);
    updateHeading();

    // Load the default location (from cache if present, else fetch)
    await runAnalysis(false);

    wireControls();
  }

  // Draw / redraw the search-center marker and the radius ring for the current state.
  function redrawCenter(fitBounds: boolean) {
    const L = (window as any).L;
    if (centerMarker) map.removeLayer(centerMarker);
    if (radiusCircle) map.removeLayer(radiusCircle);

    centerMarker = L.circleMarker([currentLat, currentLng], {
      radius: 7,
      fillColor: '#0a0a0a',
      color: '#0a0a0a',
      weight: 2,
      opacity: 1,
      fillOpacity: 0.9,
    })
      .addTo(map)
      .bindPopup(`<strong>${currentPlaceName}</strong><br>Search center`);

    radiusCircle = L.circle([currentLat, currentLng], {
      radius: currentRadiusMiles * MILES_TO_KM * 1000,
      color: '#737373',
      fillColor: '#737373',
      fillOpacity: 0.04,
      weight: 1,
      dashArray: '4, 6',
    }).addTo(map);

    if (fitBounds) {
      map.flyToBounds(radiusCircle.getBounds(), { padding: [24, 24], duration: 0.6 });
    }
  }

  function updateHeading() {
    const heading = document.getElementById('birds-heading');
    const subtitle = document.getElementById('birds-subtitle');
    if (heading) heading.textContent = `Birds of Prey Near ${currentPlaceName}`;
    if (subtitle) {
      subtitle.textContent = `Recent sightings within ${currentRadiusMiles} miles of ${currentPlaceName} — from GBIF`;
    }
  }

  // Run the analysis for the current location/radius: use cache when available, else fetch.
  async function runAnalysis(forceFetch: boolean) {
    updateHeading();
    const key = cacheKey(currentLat, currentLng, currentRadiusMiles);
    const filter = (document.getElementById('birds-taxon') as HTMLSelectElement).value;

    if (!forceFetch) {
      const cached = await loadFromCache(key);
      if (cached && Array.isArray(cached.occurrences)) {
        cachedOccurrences = cached.occurrences;
        cachedSpeciesNames = cached.speciesNames;
        displayBirdData(filter);
        updateCacheStatus(cached.timestamp);
        return;
      }
    }
    await fetchAndCacheBirdData(filter);
  }

  // Geocode an address / place name via Nominatim (OpenStreetMap). No API key needed.
  async function geocodeAddress(query: string): Promise<{ lat: number; lng: number; displayName: string } | null> {
    const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`Geocoding failed: ${res.status}`);
    const data = await res.json();
    if (!data || data.length === 0) return null;
    return {
      lat: parseFloat(data[0].lat),
      lng: parseFloat(data[0].lon),
      displayName: data[0].display_name,
    };
  }

  // Trim Nominatim's long display_name to something heading-friendly.
  function shortPlaceName(displayName: string): string {
    const parts = displayName.split(',').map((s) => s.trim()).filter(Boolean);
    if (parts.length <= 2) return displayName;
    return `${parts[0]}, ${parts[parts.length - 2]}`;
  }

  function wireControls() {
    // Address search
    const form = document.getElementById('birds-search-form') as HTMLFormElement;
    const input = document.getElementById('birds-address') as HTMLInputElement;
    const searchBtn = document.getElementById('birds-search-btn') as HTMLButtonElement;
    const placeEl = document.getElementById('birds-place')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;

      placeEl.textContent = 'Finding location…';
      placeEl.className = 'birds-place';
      searchBtn.disabled = true;

      try {
        const geo = await geocodeAddress(q);
        if (!geo) {
          placeEl.textContent = `Couldn't find "${q}". Try a city, ZIP code, or a more specific address.`;
          placeEl.className = 'birds-place birds-place-error';
          return;
        }
        currentLat = geo.lat;
        currentLng = geo.lng;
        currentPlaceName = shortPlaceName(geo.displayName);
        placeEl.innerHTML = `Showing results within ${currentRadiusMiles} mi of <strong>${geo.displayName}</strong>`;
        placeEl.className = 'birds-place';
        redrawCenter(true);
        await runAnalysis(false);
      } catch (err) {
        console.error(err);
        placeEl.textContent = 'Location lookup failed. Please check your connection and try again.';
        placeEl.className = 'birds-place birds-place-error';
      } finally {
        searchBtn.disabled = false;
      }
    });

    // Radius slider — update the label live, re-run on release (debounced)
    const slider = document.getElementById('birds-radius-slider') as HTMLInputElement;
    const radiusValue = document.getElementById('birds-radius-value')!;
    let radiusTimer: number | undefined;

    slider.addEventListener('input', () => {
      radiusValue.textContent = slider.value;
    });

    slider.addEventListener('change', () => {
      currentRadiusMiles = parseInt(slider.value, 10);
      redrawCenter(true);
      window.clearTimeout(radiusTimer);
      radiusTimer = window.setTimeout(() => runAnalysis(false), 250);
    });

    // Taxon filter — re-render from cache
    document.getElementById('birds-taxon')!.addEventListener('change', (e) => {
      const value = (e.target as HTMLSelectElement).value;
      displayBirdData(value);
    });

    // Force refresh from the API for the current location
    document.getElementById('birds-refresh')!.addEventListener('click', async () => {
      await runAnalysis(true);
    });
  }

  // Fetch JSON with retry + backoff. GBIF returns 429 under bursts of requests;
  // a short exponential backoff (honoring Retry-After when present) recovers cleanly.
  async function fetchJsonWithRetry(url: string, tries = 4): Promise<any> {
    let delay = 600;
    for (let attempt = 0; attempt < tries; attempt++) {
      const res = await fetch(url);
      if (res.ok) return res.json();
      const retryable = res.status === 429 || res.status >= 500;
      if (!retryable || attempt === tries - 1) {
        throw new Error(`GBIF API error: ${res.status}`);
      }
      const retryAfter = parseInt(res.headers.get('retry-after') || '', 10);
      const wait = Number.isFinite(retryAfter) ? retryAfter * 1000 : delay;
      await new Promise((r) => setTimeout(r, wait));
      delay *= 2;
    }
  }

  // Fetch fresh data from API and cache it
  async function fetchAndCacheBirdData(currentFilter: string) {
    const elLoading = document.getElementById('birds-loading')!;
    const elError = document.getElementById('birds-error')!;

    // Clear existing markers
    markers.forEach((m) => map.removeLayer(m));
    markers = [];

    elLoading.style.display = 'block';
    elError.style.display = 'none';

    try {
      // Always fetch ALL taxa to build complete cache
      const allTaxonKeys = TAXON_KEYS.all;
      const allOccurrences: any[] = [];

      const GBIF_LIMIT = 300;
      const MAX_PAGES = 4;

      for (const taxonKey of allTaxonKeys) {
        let offset = 0;
        let page = 0;
        let hasMore = true;

        while (hasMore && page < MAX_PAGES) {
          const params = new URLSearchParams({
            taxonKey: String(taxonKey),
            geoDistance: `${currentLat},${currentLng},${currentRadiusMiles}mi`,
            hasCoordinate: 'true',
            hasGeospatialIssue: 'false',
            limit: String(GBIF_LIMIT),
            offset: String(offset),
            year: `${new Date().getFullYear() - 5},${new Date().getFullYear()}`,
          });

          const data = await fetchJsonWithRetry(
            `https://api.gbif.org/v1/occurrence/search?${params}`
          );
          allOccurrences.push(...data.results);

          hasMore = data.endOfRecords === false && data.results.length === GBIF_LIMIT;
          offset += GBIF_LIMIT;
          page++;
        }
      }

      // Filter to valid raptors
      const validOccurrences = allOccurrences.filter(occ => {
        if (!occ.decimalLatitude || !occ.decimalLongitude) return false;
        if (!occ.order || !VALID_RAPTOR_ORDERS.includes(occ.order)) return false;
        if (!occ.species && !occ.genericName) return false;
        return true;
      });

      // Store in memory cache - only keep fields we need to reduce size
      cachedOccurrences = validOccurrences.map(occ => ({
        decimalLatitude: occ.decimalLatitude,
        decimalLongitude: occ.decimalLongitude,
        species: occ.species,
        genericName: occ.genericName,
        order: occ.order,
        family: occ.family,
        eventDate: occ.eventDate,
        stateProvince: occ.stateProvince,
        speciesKey: occ.speciesKey,
        taxonKey: occ.taxonKey,
      }));

      // Build species data and fetch common names
      speciesData.clear();
      for (const occ of validOccurrences) {
        const speciesName = occ.species || occ.genericName;
        if (!speciesData.has(speciesName)) {
          speciesData.set(speciesName, {
            scientificName: speciesName,
            vernacularName: '',
            order: occ.order,
            family: occ.family || 'Unknown',
            count: 1,
            gbifKey: occ.speciesKey || occ.taxonKey || 0,
          });
        } else {
          speciesData.get(speciesName)!.count++;
        }
      }

      // Fetch common names
      await fetchMissingCommonNames();

      // Cache species names for future use
      cachedSpeciesNames = {};
      speciesData.forEach((info, name) => {
        if (info.vernacularName) {
          cachedSpeciesNames[name] = info.vernacularName;
        }
      });

      // Save to IndexedDB under this location's key
      await saveToCache(cacheKey(currentLat, currentLng, currentRadiusMiles), cachedOccurrences, cachedSpeciesNames);

      elLoading.style.display = 'none';

      // Display with current filter
      displayBirdData(currentFilter);

    } catch (err) {
      elLoading.style.display = 'none';
      elError.style.display = 'block';
      elError.textContent = 'Bird data is temporarily unavailable (the GBIF service may be busy). Please try again in a moment.';
      console.error(err);

      // Clear the stale view so we don't show a previous location's results under the new heading.
      markers.forEach((m) => map.removeLayer(m));
      markers = [];
      cachedOccurrences = [];
      speciesData.clear();
      const gridEl = document.getElementById('birds-species-grid');
      if (gridEl) gridEl.innerHTML = '';
      const insightsEl = document.getElementById('birds-insights');
      if (insightsEl) insightsEl.style.display = 'none';
      document.getElementById('birds-count')!.textContent = '0 sightings';
      document.getElementById('birds-species')!.textContent = '0 species';
    }
  }

  // Display data from cache, filtered by taxon
  function displayBirdData(taxonFilter: string) {
    const L = (window as any).L;
    const elLoading = document.getElementById('birds-loading')!;
    const elCount = document.getElementById('birds-count')!;
    const elSpecies = document.getElementById('birds-species')!;

    elLoading.style.display = 'none';

    // Clear existing markers
    markers.forEach((m) => map.removeLayer(m));
    markers = [];

    if (cachedOccurrences.length === 0) {
      elCount.textContent = '0 sightings';
      elSpecies.textContent = '0 species';
      return;
    }

    // Filter by selected taxon
    const taxonKeys = TAXON_KEYS[taxonFilter as keyof typeof TAXON_KEYS];
    const orderMap: Record<number, string> = {
      2877: 'Accipitriformes',
      7191: 'Falconiformes',
      1458: 'Strigiformes',
    };
    const allowedOrders = taxonKeys.map(k => orderMap[k]);

    const filteredOccurrences = cachedOccurrences.filter(occ =>
      allowedOrders.includes(occ.order)
    );

    // Rebuild species data for filtered view
    speciesData.clear();
    for (const occ of filteredOccurrences) {
      const speciesName = occ.species || occ.genericName;

      if (speciesData.has(speciesName)) {
        speciesData.get(speciesName)!.count++;
      } else {
        speciesData.set(speciesName, {
          scientificName: speciesName,
          vernacularName: cachedSpeciesNames[speciesName] || '',
          order: occ.order,
          family: occ.family || 'Unknown',
          count: 1,
          gbifKey: occ.speciesKey || occ.taxonKey || 0,
        });
      }

      // Create marker
      const marker = L.circleMarker([occ.decimalLatitude, occ.decimalLongitude], {
        radius: 6,
        fillColor: getColorForOrder(occ.order),
        color: '#fff',
        weight: 1,
        opacity: 1,
        fillOpacity: 0.8,
      });

      const date = occ.eventDate
        ? new Date(occ.eventDate).toLocaleDateString()
        : 'Date unknown';

      marker.bindPopup(`
        <strong>${speciesName}</strong><br>
        Order: ${occ.order}<br>
        Date: ${date}<br>
        ${occ.stateProvince ? `Location: ${occ.stateProvince}<br>` : ''}
        <button class="popup-species-btn" onclick="window.openSpeciesModal('${speciesName.replace(/'/g, "\\'")}')">View Species Details</button>
      `);

      marker.addTo(map);
      markers.push(marker);
    }

    // Render species list + area insights
    renderSpeciesList();
    renderInsights(filteredOccurrences.length);

    elCount.textContent = `${filteredOccurrences.length} sightings`;
    elSpecies.textContent = `${speciesData.size} species`;
  }

  // Capitalize the first letter (for size-class labels etc.)
  function capitalize(s: string): string {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  // Relative-frequency label for a species, scaled against the most-reported one here.
  function frequencyLabel(count: number, maxCount: number): { text: string; cls: string } {
    const ratio = maxCount > 0 ? count / maxCount : 0;
    if (ratio >= 0.5) return { text: 'Common here', cls: 'freq-common' };
    if (ratio >= 0.15) return { text: 'Regular here', cls: 'freq-regular' };
    if (ratio >= 0.04) return { text: 'Occasional', cls: 'freq-occasional' };
    return { text: 'Rare here', cls: 'freq-rare' };
  }

  // Plain-language summary panel above the species grid.
  function renderInsights(totalSightings: number) {
    const el = document.getElementById('birds-insights');
    if (!el) return;
    el.style.display = 'block';

    const entries = Array.from(speciesData.entries())
      .filter(([name, info]) => name !== 'Unknown' && info.order !== 'Unknown')
      .sort((a, b) => b[1].count - a[1].count);

    if (entries.length === 0) {
      el.innerHTML = `<p class="birds-insights-lead">No birds of prey were reported within ${currentRadiusMiles} miles of <strong>${currentPlaceName}</strong> in the last five years. Try widening the radius or searching a different place.</p>`;
      return;
    }

    const nameOf = ([name, info]: [string, SpeciesInfo]) => info.vernacularName || name;
    const top = entries[0];
    const rare = entries[entries.length - 1];

    const orders: Record<string, number> = { Accipitriformes: 0, Falconiformes: 0, Strigiformes: 0 };
    entries.forEach(([, info]) => {
      if (orders[info.order] !== undefined) orders[info.order]++;
    });

    // Only call out a "rare find" when it's genuinely uncommon relative to the top species.
    const showRare = rare[0] !== top[0] && rare[1].count <= Math.max(2, top[1].count * 0.1);
    const rareSentence = showRare
      ? ` A rarer find here is <strong>${nameOf(rare)}</strong>, with just ${rare[1].count} ${rare[1].count === 1 ? 'report' : 'reports'}.`
      : '';

    el.innerHTML = `
      <div class="birds-insights-grid">
        <div class="insight-stat"><span class="insight-num">${entries.length}</span><span class="insight-label">species</span></div>
        <div class="insight-stat"><span class="insight-num">${totalSightings}</span><span class="insight-label">sightings</span></div>
        <div class="insight-stat"><span class="insight-num">${currentRadiusMiles}</span><span class="insight-label">mile radius</span></div>
      </div>
      <p class="birds-insights-lead">
        Within ${currentRadiusMiles} miles of <strong>${currentPlaceName}</strong>, observers have logged
        <strong>${entries.length}</strong> ${entries.length === 1 ? 'species' : 'species'} of birds of prey.
        The one you're most likely to see is <strong>${nameOf(top)}</strong>
        (${top[1].count} ${top[1].count === 1 ? 'report' : 'reports'}).${rareSentence}
      </p>
      <div class="birds-insights-breakdown">
        <span><span class="dot-inline" style="background:#ef4444"></span> ${orders.Accipitriformes} hawk &amp; eagle ${orders.Accipitriformes === 1 ? 'species' : 'species'}</span>
        <span><span class="dot-inline" style="background:#f97316"></span> ${orders.Falconiformes} falcon ${orders.Falconiformes === 1 ? 'species' : 'species'}</span>
        <span><span class="dot-inline" style="background:#3b82f6"></span> ${orders.Strigiformes} owl ${orders.Strigiformes === 1 ? 'species' : 'species'}</span>
      </div>
    `;
  }

  function getColorForOrder(order: string): string {
    switch (order) {
      case 'Accipitriformes':
        return '#ef4444'; // Red - Hawks, Eagles
      case 'Falconiformes':
        return '#f97316'; // Orange - Falcons
      case 'Strigiformes':
        return '#3b82f6'; // Blue - Owls
      default:
        return '#6b7280'; // Gray
    }
  }

  // Fetch common names for species missing vernacularName
  // Uses multiple sources: Wikipedia (best for English), iNaturalist, then GBIF
  async function fetchMissingCommonNames() {
    const speciesNeedingNames = Array.from(speciesData.entries())
      .filter(([_, info]) => !info.vernacularName)
      .slice(0, 50);

    const fetchPromises = speciesNeedingNames.map(async ([name, info]) => {
      try {
        // 1. Try Wikipedia first - article titles are often common English names
        const wikiTitle = name.replace(/ /g, '_');
        const wikiResponse = await fetch(
          `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(wikiTitle)}`
        );
        if (wikiResponse.ok) {
          const wikiData = await wikiResponse.json();
          // Wikipedia often redirects scientific names to common name articles
          // Check if title differs from scientific name and looks like English
          const pageTitle = wikiData.title;
          if (pageTitle &&
              pageTitle.toLowerCase() !== name.toLowerCase() &&
              /^[A-Za-z\s\-']+$/.test(pageTitle)) {
            info.vernacularName = pageTitle;
            return;
          }
        }

        // 2. Try iNaturalist - use both english_common_name and preferred_common_name
        const inatResponse = await fetch(
          `https://api.inaturalist.org/v1/taxa?q=${encodeURIComponent(name)}&rank=species&per_page=1&locale=en`
        );
        if (inatResponse.ok) {
          const inatData = await inatResponse.json();
          const taxon = inatData.results?.[0];
          const commonName = taxon?.english_common_name || taxon?.preferred_common_name;
          if (commonName && /^[A-Za-z\s\-']+$/.test(commonName)) {
            info.vernacularName = commonName;
            return;
          }
        }

        // 3. Last resort: GBIF with strict ASCII check
        if (info.gbifKey) {
          const response = await fetch(
            `https://api.gbif.org/v1/species/${info.gbifKey}/vernacularNames?limit=20`
          );
          if (response.ok) {
            const data = await response.json();
            const englishName = data.results?.find(
              (n: any) => (n.language === 'eng' || n.language === 'en') &&
                          /^[A-Za-z\s\-']+$/.test(n.vernacularName)
            );
            if (englishName?.vernacularName) {
              info.vernacularName = englishName.vernacularName;
            }
          }
        }
      } catch {
        // Ignore errors for individual species lookups
      }
    });

    await Promise.all(fetchPromises);
  }

  /* ── Species Grid ── */
  function renderSpeciesList() {
    const gridEl = document.getElementById('birds-species-grid')!;
    const countLabel = document.getElementById('birds-species-count-label')!;
    gridEl.innerHTML = '';

    // Filter out unknown and sort by count descending
    const filtered = Array.from(speciesData.entries())
      .filter(([name, info]) => name !== 'Unknown' && info.order !== 'Unknown')
      .sort((a, b) => b[1].count - a[1].count);

    countLabel.textContent = `(${filtered.length})`;

    const maxCount = filtered.length > 0 ? filtered[0][1].count : 0;

    for (const [name, info] of filtered) {
      const displayName = info.vernacularName || name;
      const raptor = getRaptorInfo(name, info.family);
      const freq = frequencyLabel(info.count, maxCount);
      const sizeText = raptor
        ? `${capitalize(raptor.sizeClass)} · ${raptor.wingspanCm[0]}–${raptor.wingspanCm[1]} cm wingspan`
        : '';

      const card = document.createElement('div');
      card.className = 'species-card';
      card.innerHTML = `
        <div class="species-card-color" style="background: ${getColorForOrder(info.order)}"></div>
        <div class="species-card-content">
          <span class="species-card-common">${displayName}</span>
          <span class="species-card-scientific">${name}</span>
          ${sizeText ? `<span class="species-card-size">${sizeText}</span>` : ''}
        </div>
        <div class="species-card-meta">
          <span class="species-freq ${freq.cls}">${freq.text}</span>
          <span class="species-card-count">${info.count} ${info.count === 1 ? 'report' : 'reports'}</span>
        </div>
      `;
      card.addEventListener('click', () => openSpeciesModal(name));
      gridEl.appendChild(card);
    }
  }

  /* ── Species Modal ── */
  async function openSpeciesModal(speciesName: string) {
    const modal = document.getElementById('species-modal')!;
    const loading = document.getElementById('species-modal-loading')!;
    const body = document.getElementById('species-modal-body')!;

    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    loading.style.display = 'block';
    body.style.display = 'none';

    const info = speciesData.get(speciesName);
    if (!info) {
      loading.textContent = 'Species not found';
      return;
    }

    try {
      // Fetch data from both APIs in parallel
      const [wikiData, inatData] = await Promise.all([
        fetchWikipediaData(speciesName),
        fetchINaturalistData(speciesName),
      ]);

      // Populate modal
      document.getElementById('species-modal-name')!.textContent = speciesName;
      document.getElementById('species-modal-common')!.textContent = info.vernacularName || wikiData.commonName || inatData.commonName || '';
      document.getElementById('species-modal-order')!.textContent = info.order;
      document.getElementById('species-modal-family')!.textContent = info.family;
      document.getElementById('species-modal-sightings')!.textContent = `${info.count} sightings`;

      // Description from Wikipedia
      const descEl = document.getElementById('species-modal-description')!;
      descEl.innerHTML = wikiData.extract || '<em>No description available.</em>';

      // Curated enrichment: how-to-spot notes, wingspan visual, seasonality
      const raptor = getRaptorInfo(speciesName, info.family);
      renderFieldNotes(raptor);
      renderWingspanBar(raptor);
      renderSeasonality(speciesName);

      // Images - prefer iNaturalist, fallback to Wikipedia
      const mainImage = document.getElementById('species-modal-image') as HTMLImageElement;
      const thumbnails = document.getElementById('species-modal-thumbnails')!;
      thumbnails.innerHTML = '';

      // iNaturalist large photos lead — Wikipedia appended as supplement only
      const allPhotos = [...inatData.photos];
      if (wikiData.image && !allPhotos.includes(wikiData.image)) {
        allPhotos.push(wikiData.image);
      }

      if (allPhotos.length > 0) {
        mainImage.src = allPhotos[0];
        mainImage.alt = speciesName;
        mainImage.style.display = 'block';

        // Add thumbnails if multiple photos
        if (allPhotos.length > 1) {
          allPhotos.slice(0, 6).forEach((url, idx) => {
            const thumb = document.createElement('img');
            thumb.src = url;
            thumb.alt = `${speciesName} photo ${idx + 1}`;
            thumb.className = idx === 0 ? 'active' : '';
            thumb.addEventListener('click', () => {
              mainImage.src = url;
              thumbnails.querySelectorAll('img').forEach(t => t.classList.remove('active'));
              thumb.classList.add('active');
            });
            thumbnails.appendChild(thumb);
          });
        }
      } else {
        mainImage.style.display = 'none';
      }

      // Links
      const wikiTitle = speciesName.replace(/ /g, '_');
      (document.getElementById('species-link-wikipedia') as HTMLAnchorElement).href =
        `https://en.wikipedia.org/wiki/${wikiTitle}`;
      (document.getElementById('species-link-inaturalist') as HTMLAnchorElement).href =
        `https://www.inaturalist.org/taxa/search?q=${encodeURIComponent(speciesName)}`;
      (document.getElementById('species-link-gbif') as HTMLAnchorElement).href =
        `https://www.gbif.org/species/${info.gbifKey}`;

      loading.style.display = 'none';
      body.style.display = 'flex';
    } catch (err) {
      console.error('Error loading species data:', err);
      loading.textContent = 'Failed to load species information.';
    }
  }

  async function fetchWikipediaData(speciesName: string): Promise<{ extract: string; image: string; commonName: string }> {
    try {
      const title = speciesName.replace(/ /g, '_');
      const response = await fetch(
        `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(title)}`
      );

      if (!response.ok) {
        return { extract: '', image: '', commonName: '' };
      }

      const data = await response.json();
      // Check if page title differs from scientific name and looks English
      const pageTitle = data.title || '';
      const isCommonName = pageTitle &&
        pageTitle.toLowerCase() !== speciesName.toLowerCase() &&
        /^[A-Za-z\s\-']+$/.test(pageTitle);

      // Require minimum 800px width — Wikipedia thumbnails can be very small
      const MIN_WIDTH = 800;
      const origSrc = data.originalimage?.source || '';
      const origWidth = data.originalimage?.width ?? 0;
      const thumbSrc = data.thumbnail?.source || '';
      const thumbWidth = data.thumbnail?.width ?? 0;
      const image = origWidth >= MIN_WIDTH ? origSrc
                  : thumbWidth >= MIN_WIDTH ? thumbSrc
                  : '';

      return {
        extract: data.extract || '',
        image,
        commonName: isCommonName ? pageTitle : '',
      };
    } catch {
      return { extract: '', image: '', commonName: '' };
    }
  }

  async function fetchINaturalistData(speciesName: string): Promise<{ photos: string[]; commonName: string }> {
    try {
      const response = await fetch(
        `https://api.inaturalist.org/v1/taxa?q=${encodeURIComponent(speciesName)}&rank=species&per_page=1&locale=en`
      );

      if (!response.ok) {
        return { photos: [], commonName: '' };
      }

      const data = await response.json();
      if (data.results && data.results.length > 0) {
        const taxon = data.results[0];
        // Gallery container is 3:2 landscape — pick the photo whose aspect ratio
        // is closest to that among the top 4 quality-ranked photos. Most bird
        // photography is already landscape, so this usually keeps the highest-quality
        // shot; it only swaps when the top photo is unusually portrait/square.
        const GALLERY_RATIO = 3 / 2;
        const rawPhotos: any[] = taxon.taxon_photos?.slice(0, 4) || [];
        const sortedPhotos = [...rawPhotos].sort((a, b) => {
          const ratio = (p: any) => {
            const w = p.photo.original_dimensions?.width || 1000;
            const h = p.photo.original_dimensions?.height || 1000;
            return w / h;
          };
          return Math.abs(ratio(a) - GALLERY_RATIO) - Math.abs(ratio(b) - GALLERY_RATIO);
        });
        const photos = sortedPhotos.map((p: any) => p.photo.large_url || p.photo.medium_url).filter(Boolean);
        // Use english_common_name or preferred_common_name if it looks English
        const commonName = taxon.english_common_name || taxon.preferred_common_name || '';
        const isEnglish = /^[A-Za-z\s\-']+$/.test(commonName);
        return {
          photos: photos.slice(0, 6),
          commonName: isEnglish ? commonName : '',
        };
      }

      return { photos: [], commonName: '' };
    } catch {
      return { photos: [], commonName: '' };
    }
  }

  // "How to spot it" — curated field marks + behavior + difficulty.
  function renderFieldNotes(raptor: RaptorInfo | null) {
    const el = document.getElementById('species-modal-fieldnotes')!;
    if (!raptor) {
      el.innerHTML = '';
      return;
    }
    const diffLabel: Record<string, string> = {
      easy: 'Easy to spot',
      moderate: 'Moderately tricky',
      tricky: 'A challenge to find & ID',
    };
    const cues = raptor.idCues.map((c) => `<li>${c}</li>`).join('');
    const fallbackNote = raptor.isFallback
      ? `<p class="fieldnotes-fallback">General notes for this group — species-specific tips aren't available for this one.</p>`
      : '';
    el.innerHTML = `
      <h4 class="species-block-title">How to spot it <span class="fieldnotes-diff">${diffLabel[raptor.difficulty]}</span></h4>
      ${fallbackNote}
      <ul class="fieldnotes-cues">${cues}</ul>
      <p class="fieldnotes-behavior">${raptor.behavior}</p>
    `;
  }

  // Wingspan visual: the species' range plotted against familiar reference points.
  function renderWingspanBar(raptor: RaptorInfo | null) {
    const el = document.getElementById('species-modal-wingspan')!;
    if (!raptor) {
      el.innerHTML = '';
      return;
    }
    const max = WINGSPAN_AXIS_MAX_CM;
    const [lo, hi] = raptor.wingspanCm;
    const leftPct = (lo / max) * 100;
    const widthPct = ((hi - lo) / max) * 100;
    const inLo = Math.round(lo / 2.54);
    const inHi = Math.round(hi / 2.54);

    const refs = WINGSPAN_REFERENCES.map(
      (r) => `
      <div class="wingspan-ref" style="left:${(r.cm / max) * 100}%">
        <span class="wingspan-ref-tick"></span>
        <span class="wingspan-ref-label">${r.label}<br>${r.cm} cm</span>
      </div>`
    ).join('');

    el.innerHTML = `
      <h4 class="species-block-title">Wingspan</h4>
      <div class="wingspan-track">
        <div class="wingspan-range" style="left:${leftPct}%;width:${widthPct}%"></div>
        ${refs}
      </div>
      <p class="species-block-caption">${lo}–${hi} cm (${inLo}–${inHi} in) tip to tip — a ${raptor.sizeClass} raptor.</p>
    `;
  }

  // Seasonality: when this species is reported near the current location.
  function renderSeasonality(speciesName: string) {
    const el = document.getElementById('species-modal-seasonality')!;
    const months = new Array(12).fill(0);
    let dated = 0;

    for (const occ of cachedOccurrences) {
      const nm = occ.species || occ.genericName;
      if (nm !== speciesName || !occ.eventDate) continue;
      const m = new Date(occ.eventDate).getMonth();
      if (!isNaN(m)) {
        months[m]++;
        dated++;
      }
    }

    // Too few dated records to say anything meaningful.
    if (dated < 4) {
      el.innerHTML = '';
      return;
    }

    const max = Math.max(...months);
    const short = ['J', 'F', 'M', 'A', 'M', 'J', 'J', 'A', 'S', 'O', 'N', 'D'];
    const full = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

    const peaks = months
      .map((v, i) => ({ v, i }))
      .filter((o) => o.v > 0 && o.v >= max * 0.85)
      .map((o) => full[o.i]);

    const bars = months
      .map(
        (v, i) => `
        <div class="season-bar-wrap" title="${full[i]}: ${v} ${v === 1 ? 'report' : 'reports'}">
          <div class="season-bar" style="height:${max ? (v / max) * 100 : 0}%"></div>
          <span class="season-bar-label">${short[i]}</span>
        </div>`
      )
      .join('');

    el.innerHTML = `
      <h4 class="species-block-title">When it's reported near ${currentPlaceName}</h4>
      <div class="season-chart">${bars}</div>
      <p class="species-block-caption">Most reported in ${formatPeaks(peaks)}. Based on ${dated} dated ${dated === 1 ? 'sighting' : 'sightings'} — counts reflect when people report birds, not only when the birds are present.</p>
    `;
  }

  function formatPeaks(peaks: string[]): string {
    if (peaks.length === 0) return 'no particular month';
    if (peaks.length >= 6) return 'many months (fairly year-round)';
    if (peaks.length === 1) return peaks[0];
    return peaks.slice(0, -1).join(', ') + ' and ' + peaks[peaks.length - 1];
  }

  function closeSpeciesModal() {
    const modal = document.getElementById('species-modal')!;
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  // Expose openSpeciesModal globally for popup buttons
  (window as any).openSpeciesModal = openSpeciesModal;

  // Modal event listeners
  document.getElementById('species-modal-close')!.addEventListener('click', closeSpeciesModal);
  document.querySelector('.species-modal-backdrop')!.addEventListener('click', closeSpeciesModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSpeciesModal();
  });
</script>

