---
interface SpecItem {
  label: string;
  value: string;
}

interface Props {
  specs: SpecItem[];
  sourceUrl?: string;
}

const { specs, sourceUrl } = Astro.props;
---

{specs.length > 0 && (
  <section class="tech-specs">
    <h2>Tech Specs</h2>
    <dl>
      {specs.map((spec) => (
        <div class="spec-row">
          <dt>{spec.label}</dt>
          <dd>{spec.value}</dd>
        </div>
      ))}
    </dl>
  </section>
)}

<style>
  .tech-specs {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .tech-specs h2 {
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  dl {
    margin: 0;
  }

  .spec-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0.5rem 1.5rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .spec-row:last-child {
    border-bottom: none;
  }

  dt {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    padding-top: 0.125rem;
  }

  dd {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text);
    white-space: pre-line;
  }

  .source {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .source a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .source a:hover {
    color: var(--color-muted);
  }
</style>
